{
  "name": "Upload Gmail attachments to Google Drive",
  "description": "1. A new email is received in Gmail.\n2. If the email has attachments, Workato uploads these attachments to Google Drive **My Drive**. \n\n**Notes**\nYou can specify Google Drive folder to upload attachments to.",
  "version": 3,
  "private": true,
  "concurrency": 1,
  "code": {
    "number": 0,
    "provider": "gmail",
    "name": "new_email",
    "as": "new_email",
    "keyword": "trigger",
    "dynamicPickListSelection": {
      "label_ids": "INBOX"
    },
    "input": {
      "label_ids": "INBOX"
    },
    "visible_config_fields": [
      "label_ids"
    ],
    "block": [
      {
        "number": 1,
        "as": "foreach",
        "keyword": "foreach",
        "clear_scope": false,
        "input": {
        },
        "block": [
          {
            "number": 2,
            "provider": "gmail",
            "name": "download_attachment",
            "as": "download_attachment",
            "keyword": "action",
            "input": {
              "id": "#{_dp('{\"pill_type\":\"output\",\"provider\":\"gmail\",\"line\":\"new_email\",\"path\":[\"id\"]}')}",
              "attachmentId": "#{_dp('{\"pill_type\":\"output\",\"provider\":\"foreach\",\"line\":\"foreach\",\"path\":[\"attachmentId\"]}')}"
            },
            "comment": "Download email attachments using an attachment ID",
            "uuid": "f9ec7c9e-6bec-4094-bcfd-44251f0eaada"
          },
          {
            "number": 3,
            "provider": "google_drive",
            "name": "upload_file",
            "as": "upload_file",
            "keyword": "action",
            "input": {
              "fileContent": "#{_dp('{\"pill_type\":\"output\",\"provider\":\"gmail\",\"line\":\"download_attachment\",\"path\":[\"content_bytes\"]}')}",
              "name": "#{_dp('{\"pill_type\":\"output\",\"provider\":\"foreach\",\"line\":\"foreach\",\"path\":[\"filename\"]}')}"
            },
            "uuid": "e813a0de-23e2-403e-a3a9-4d8464f3ceca"
          }
        ],
        "source": "#{_dp('{\"pill_type\":\"output\",\"provider\":\"gmail\",\"line\":\"new_email\",\"path\":[\"attachments\"]}')}",
        "uuid": "274f27ce-3363-4fda-8897-136ad0ca54e5"
      }
    ],
    "job_report_schema": [
      {
        "name": "custom_column_3",
        "label": "Email subject"
      },
      {
        "name": "custom_column_1",
        "label": "Number of files"
      },
      {
        "name": "custom_column_2",
        "label": "File names"
      }
    ],
    "job_report_config": {
      "custom_column_3": "#{_('data.gmail.new_email.subject')}",
      "custom_column_1": "#{_('data.gmail.new_email.attachments.first.____Size', 'list_meta', '____Size', 'data.gmail.new_email.attachments')}",
      "custom_column_2": "=_('data.gmail.new_email.attachments').pluck('filename').join(', ')"
    },
    "uuid": "dca75535-adaf-4274-82a2-a4841e4b99bf",
    "format_version": 2
  },
  "config": [
    {
      "keyword": "application",
      "provider": "gmail",
      "account_id": {
        "zip_name": "sample1_gmail.connection.json",
        "name": "Sample1 | Gmail",
        "folder": ""
      },
      "skip_validation": false
    },
    {
      "keyword": "application",
      "provider": "google_drive",
      "account_id": {
        "zip_name": "sample1_google_drive.connection.json",
        "name": "Sample1 | Google Drive",
        "folder": ""
      },
      "skip_validation": false
    }
  ]
}