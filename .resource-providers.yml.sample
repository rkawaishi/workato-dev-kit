# Resource provider configuration (per-environment)
# Copy this file and save it as .resource-providers.yml.
# .resource-providers.yml is gitignored.
#
# Delete or comment out providers you do not use.
# Details: docs/platform/resource-providers.md

providers:
  # --- MCP servers ---
  # tool_prefix: the prefix to search for with ToolSearch.
  # The actual prefix depends on the MCP server's configuration.

  # jira:
  #   method: mcp
  #   tool_prefix: "mcp__jira__"
  #   notes: "Jira Cloud MCP server"

  # slack:
  #   method: mcp
  #   tool_prefix: "mcp__slack__"

  # salesforce:
  #   method: mcp
  #   tool_prefix: "mcp__salesforce__"

  # google_sheets:
  #   method: mcp
  #   tool_prefix: "mcp__google_drive__"

  # --- CLI tools ---
  # command: the command name to detect via `which`.
  # auth_check: a command that verifies auth state (optional).

  # github:
  #   method: cli
  #   command: "gh"
  #   auth_check: "gh auth status"

  # workato:
  #   method: cli
  #   command: "workato"

  # --- WebFetch ---
  # base_url: the API's base URL.

  # my_api:
  #   method: webfetch
  #   base_url: "https://api.example.com"
  #   notes: "OpenAPI spec at /openapi.json"
