{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-before-push.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/multi-repo-git-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/sync-docs-after-sdk-push.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(workato:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(uuidgen)",
      "Bash(git:*)",
      "Bash(cat:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ]
  }
}
